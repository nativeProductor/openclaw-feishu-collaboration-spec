# Copy this file to .env at the project root and fill in real values.
# .env is gitignored — never commit secrets.

# --- Feishu Custom App credentials (open.feishu.cn) ---------------------------
FEISHU_APP_ID=cli_REPLACE_WITH_YOUR_APP_ID
FEISHU_APP_SECRET=REPLACE_WITH_YOUR_APP_SECRET

# --- Xiaomi MiMo Token Plan API key (platform.xiaomimimo.com) -----------------
# The Token Plan endpoint and key prefix MUST match (sgp endpoint with tp- key).
XIAOMI_TOKEN_PLAN_KEY=tp-REPLACE_WITH_YOUR_TOKEN_PLAN_KEY
XIAOMI_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1

# --- bot2 install location & runtime (defaults are fine for most users) -------
BOT2_PROJ_DIR=$HOME/openclaw-bot2
BOT2_STATE_DIR=$HOME/.openclaw-bot2
BOT2_PROFILE=bot2
BOT2_GATEWAY_PORT=18889

# --- pinned versions (bump deliberately) --------------------------------------
OPENCLAW_VERSION=2026.5.6
FEISHU_PLUGIN_VERSION=2026.5.6
PRIMARY_MODEL=xiaomi/mimo-v2.5-pro
