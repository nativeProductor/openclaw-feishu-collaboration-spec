# Test harness credentials and topology.
# Copy to .env in this directory and fill in real values. NEVER commit .env.

GROUP_CHAT_ID=oc_REPLACE_WITH_YOUR_TEST_GROUP_ID

BOT1_APP_ID=cli_REPLACE_WITH_BOT1_APP_ID
BOT1_APP_SECRET=REPLACE_WITH_BOT1_APP_SECRET
BOT1_OPEN_ID=ou_REPLACE_WITH_BOT1_OPEN_ID_AS_BOT1_SEES_ITSELF
BOT1_NAME=bot1
BOT1_REMOTE_HOST=root@REPLACE_WITH_HOST_OR_localhost

BOT2_APP_ID=cli_REPLACE_WITH_BOT2_APP_ID
BOT2_APP_SECRET=REPLACE_WITH_BOT2_APP_SECRET
BOT2_OPEN_ID=ou_REPLACE_WITH_BOT2_OPEN_ID_AS_BOT2_SEES_ITSELF
BOT2_NAME=bot2
BOT2_LOG_FILE=/path/to/.openclaw-bot2/logs/gateway.log
