# -----------------------------------------------------------------------------
# Dev / process artifacts — kept local, never pushed to the public repo.
# These are the byproducts of plugin development and verification, not part
# of the plugin's runtime or installable surface.
# -----------------------------------------------------------------------------

# Internal design history & research
docs/architecture.md
docs/memory-core-audit.md
docs/cross-bot-identity-research.md
docs/inbound-claim-debug.md
docs/PM-review-*.md

# Internal QA acceptance plan
plugin/TEST-PLAN.md

# Local test harness (lark-cli wrappers for sending stimuli + log watching)
harness/

# Dev bootstrap scripts (spin up a local dev bot, sync local doc to Feishu)
scripts/
# …but ensure-hooks.mjs is a user-facing runtime helper (referenced by
# README install instructions), not a dev artifact — keep it tracked.
!scripts/ensure-hooks.mjs

# Project root env scaffolding (only needed by the local dev scripts above)
.env.example
.feishu-doc-id
